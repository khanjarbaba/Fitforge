// FitForge Firestore Security Rules
// Paste these into: Firebase Console → Firestore Database → Rules → Publish
//
// - Each user's workout data (users/{uid}/data/...) stays private to that user.
// - The leaderboard is readable by any signed-in user, but each person can only
//   write their OWN row — so nobody can edit someone else's score.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Private per-user workout data
    match /users/{userId}/data/{document} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Public leaderboard — one row per user at leaderboard/{uid}
    match /leaderboard/{userId} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
    }
  }
}
